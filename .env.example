OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_PLANNER_MODEL=gpt-4o-mini
PDF_ROOT=data/pdfs
CHROMA_PATH=data/chromadb
CHROMA_COLLECTION=swiss_procedures
CHUNK_SIZE_WORDS=600
CHUNK_OVERLAP_WORDS=100
RETRIEVAL_TOP_K=10
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=5
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
SQLITE_DATABASE_URL=sqlite:///data/sqlite/memory.db
REQUEST_TIMEOUT_SECONDS=60

MCP_SERVER_NAME=Swiss Lawyer
MCP_SERVER_VERSION=1.0.0
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_PATH=/mcp
MCP_AUTH_MODE=single_user
MCP_SINGLE_USER_KEY=replace-with-a-private-local-key
MCP_PUBLIC_BASE_URL=
SWISS_LAWYER_API_BASE_URL=http://api:8000
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-value
MCP_BACKEND_TIMEOUT_SECONDS=90
MCP_MAX_QUESTION_LENGTH=10000
MCP_MAX_PROFILE_FIELDS=50
MCP_MAX_PROGRESS_NOTE_LENGTH=5000
MCP_RATE_LIMIT_REQUESTS_PER_MINUTE=30
NGROK_DOMAIN=

ENABLE_SYNC_ADMIN_ENDPOINTS=false
SYNC_SOURCE_REGISTRY_PATH=data/pdfs/metadata/sources.yaml
SYNC_PDF_PATH=data/pdfs
SYNC_DOCUMENT_PATH=data/documents
SYNC_TEMP_DOWNLOAD_PATH=data/tmp/synchronizer
SYNC_HTTP_TIMEOUT_SECONDS=30
SYNC_MAX_DOCUMENT_BYTES=20000000
SYNC_RETRY_COUNT=2
SYNC_RETRY_BACKOFF_SECONDS=0.25
SYNC_USER_AGENT=Swiss Lawyer MCP Synchronizer/0.9
SYNC_RETAIN_UNAVAILABLE_SOURCES=true
SYNC_CANDIDATE_DISCOVERY_ENABLED=true
SYNC_WEBPAGE_MIN_CONTENT_CHARS=100
